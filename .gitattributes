# Normalize line endings across platforms
* text=auto

# Force LF for source code and configs
*.py text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf

# Force CRLF for Windows-specific files (se necessário)
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files - keep untouched
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.zip binary
*.exe binary
*.dll binary
*.so binary
*.pyd binary
